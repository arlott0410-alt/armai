# API base URL (defaults to /api if unset)
# VITE_API_URL=https://your-worker.workers.dev/api

# Supabase (required for auth)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Facebook Messenger connect (Channels page). Get from Meta for Developers → Your App → Settings → Basic.
# VITE_FACEBOOK_APP_ID=
